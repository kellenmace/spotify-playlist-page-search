{
  "manifest_version": 3,
  "name": "Spotify Playlist Page Search",
  "version": "2.0.0",
  "description": "Search for songs within Spotify playlists",
  "author": "Kellen Mace",
  "homepage_url": "https://github.com/kellenmace/spotify-playlist-page-search/",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["scripting", "tabs", "webNavigation"],
  "host_permissions": ["https://open.spotify.com/*"],
  "commands": {
    "toggle-search": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Toggle playlist search modal"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/playlist/*"],
      "js": ["content-script.js"],
      "css": ["content-script.css"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["page-fetch-interceptor.js"],
      "matches": ["https://open.spotify.com/*"]
    }
  ]
}
